{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.upwindchange.Autai",
  "productName": "Autai",
  "asar": true,
  "asarUnpack": ["out/main/better_sqlite3.node"],
  "directories": {
    "output": "release/${version}"
  },
  "files": ["out"],
  "extraResources": [
    {
      "from": "resources",
      "to": "resources"
    }
  ],
  "mac": {
    "artifactName": "${productName}_${version}_${os}_${arch}.${ext}",
    "target": ["zip"]
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64", "arm64"]
      }
    ],
    "artifactName": "${productName}_${version}_${os}_${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "linux": {
    "artifactName": "${productName}_${version}_${os}_${arch}.${ext}",
    "target": [{ "target": "AppImage", "arch": ["x64", "arm64"] }],
    "category": "Utility"
  },
  "flatpak": {
    "runtimeVersion": "25.08",
    "baseVersion": "25.08"
  },
  "publish": {
    "provider": "github",
    "owner": "upwindchange",
    "repo": "Autai"
  }
}
