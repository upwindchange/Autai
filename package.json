  "private": true,
  "description": "Autai - AI-Powered Browser Automation",
  "license": "MIT",
  "author": "Yuwei Zhu <zyw@tutamail.com>",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite build && electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:vite": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:all": "node scripts/build-all-platforms.js",
    "preview": "electron-vite preview",
    "start": "electron-vite preview --skipBuild",
    "tsc:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "tsc:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "tsc": "pnpm tsc:node && pnpm tsc:web",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write src/",
    "postinstall": "node scripts/postinstall.js",
    "db:generate": "drizzle-kit generate",
    "db:generate:custom": "drizzle-kit generate --custom"
  },
  "prettier": {
    "experimentalTernaries": true,
    "tabWidth": 2,
    "useTabs": false
