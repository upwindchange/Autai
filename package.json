{
	"name": "autai",
	"version": "0.0.0",
	"private": true,
	"description": "Automatic AI Agent Driven Browser",
	"license": "MIT",
	"author": "Yuwei Zhu <zyw@tutamail.com>",
	"type": "module",
	"main": "out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build && electron-builder",
		"preview": "electron-vite preview",
		"start": "electron-vite preview --skipBuild",
		"tsc:node": "tsc --noEmit -p tsconfig.node.json --composite false",
		"tsc:web": "tsc --noEmit -p tsconfig.web.json --composite false",
		"tsc": "pnpm tsc:node && pnpm tsc:web",
		"test": "vitest run",
		"lint": "eslint .",
		"format": "prettier --write src/",
		"postinstall": "node scripts/postinstall.js"
	},
	"prettier": {
		"experimentalTernaries": true,
		"tabWidth": 2,
		"useTabs": true
	},
